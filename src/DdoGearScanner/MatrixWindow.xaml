<Window x:Class="DdoGearScanner.MatrixWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Stacking Matrix" Width="1100" Height="700"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/appicon.ico"
        Background="{StaticResource BgWindow}" Foreground="{StaticResource Parchment}"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
            <Setter Property="FontSize" Value="12.5" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="0">
        <!-- Header band -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BgPanel}" Padding="20,14"
                BorderBrush="{StaticResource BorderGold}" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Stacking Matrix" FontSize="20" Style="{StaticResource Title}" />
                <TextBlock x:Name="Summary" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0" FontSize="12.5" />
            </StackPanel>
        </Border>

        <!-- Legend + controls -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BgWindow}" Padding="20,9"
                BorderBrush="{StaticResource BorderDim}" BorderThickness="0,0,0,1">
            <DockPanel>
                <CheckBox x:Name="ConflictsOnly" DockPanel.Dock="Right" Content="Conflicts only"
                          Foreground="{StaticResource Parchment}" VerticalAlignment="Center" Checked="ConflictsOnly_Changed"
                          Unchecked="ConflictsOnly_Changed" />
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#182C1A" CornerRadius="9" Padding="9,2" Margin="0,0,8,0">
                        <TextBlock Text="+N counts" Foreground="#8FCF8A" />
                    </Border>
                    <Border Background="#35201C" CornerRadius="9" Padding="9,2" Margin="0,0,8,0">
                        <TextBlock Text="+N overridden" Foreground="#DA6E5E"
                                   TextDecorations="Strikethrough" />
                    </Border>
                    <TextBlock Text="A/B/C = gear priority (gold/silver/bronze) · &quot;= N&quot; shows a sum only where a type actually stacks"
                               Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.IsSharedSizeScope="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Frozen header (scrolls horizontally in sync with the body, but never vertically) -->
            <ScrollViewer x:Name="HeaderScroll" Grid.Row="0" Padding="20,0" Background="{StaticResource BgPanelAlt}"
                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                <Grid x:Name="HeaderGrid" />
            </ScrollViewer>

            <ScrollViewer x:Name="BodyScroll" Grid.Row="1" Padding="20,0,20,12"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          ScrollChanged="BodyScroll_ScrollChanged">
                <StackPanel>
                    <Grid x:Name="MatrixGrid" />
                    <TextBlock x:Name="NamedHeader" Foreground="#E6B45C" FontWeight="SemiBold" FontSize="13"
                               Margin="2,24,0,2" Text="Item-local effects  (weapon/armor enchants &amp; procs — only affect their own item)"
                               Visibility="Collapsed" />
                    <StackPanel x:Name="NamedList" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
