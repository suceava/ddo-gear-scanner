<Window x:Class="DdoGearScanner.RunTrackerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Run Tracker" Width="1000" Height="620"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/appicon.ico"
        Background="{StaticResource BgWindow}" Foreground="{StaticResource Parchment}"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <!-- Minimal dark theming for the DataGrid (the default template is light). -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource BgPanelAlt}" />
            <Setter Property="Foreground" Value="{StaticResource Gold}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDim}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource Parchment}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBg}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Compact header: title + controls -->
        <Border DockPanel.Dock="Top" Background="{StaticResource BgPanel}" Padding="20,10"
                BorderBrush="{StaticResource BorderGold}" BorderThickness="0,0,0,1">
            <DockPanel>
                <CheckBox x:Name="TrackingToggle" DockPanel.Dock="Right" Content="Tracking on"
                          Foreground="{StaticResource Parchment}" VerticalAlignment="Center"
                          Checked="Tracking_Changed" Unchecked="Tracking_Changed" />
                <Button x:Name="RefreshButton" DockPanel.Dock="Right" Content="Refresh" Click="Refresh_Click"
                        VerticalAlignment="Center" Margin="0,0,12,0" />
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Run Tracker" FontSize="17" Style="{StaticResource Title}" />
                    <TextBlock x:Name="Subtitle" Foreground="{StaticResource TextMuted}" Margin="0,1,0,0" FontSize="11.5" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Prominent CURRENT RUN hero card -->
        <Border x:Name="CurrentCard" DockPanel.Dock="Top" Background="{StaticResource BgPanelAlt}" Padding="24,18"
                BorderBrush="{StaticResource BorderGold}" BorderThickness="0,0,0,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock x:Name="CurrentLabel" Text="CURRENT RUN" Foreground="{StaticResource Gold}"
                               FontSize="11" FontWeight="Bold" />
                    <TextBlock x:Name="CurrentName" Text="No active run" FontSize="18" Style="{StaticResource Title}"
                               TextTrimming="CharacterEllipsis" Margin="0,4,0,0" />
                    <StackPanel x:Name="CurrentMeta" Orientation="Horizontal" Margin="0,10,0,0" />
                </StackPanel>
                <TextBlock x:Name="CurrentTimer" Grid.Column="1" Text="" FontSize="26" FontFamily="Consolas"
                           Foreground="{StaticResource GoldBright}" VerticalAlignment="Center" Margin="16,0,0,0" />
            </Grid>
        </Border>

        <DataGrid x:Name="Grid" Margin="20,12" AutoGenerateColumns="False" CanUserAddRows="False"
                  CanUserDeleteRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{StaticResource BorderDim}" Background="{StaticResource BgWindow}"
                  RowBackground="{StaticResource BgPanel}" AlternatingRowBackground="{StaticResource BgPanelAlt}"
                  BorderBrush="{StaticResource BorderDim}" BorderThickness="1" SelectionMode="Single"
                  CellEditEnding="Grid_CellEditEnding" ColumnWidth="Auto" RowHeight="30">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Dungeon" Binding="{Binding Dungeon}" Width="*" MinWidth="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Difficulty" Binding="{Binding Difficulty}" Width="82" />
                <DataGridTextColumn Header="Lvl" Binding="{Binding Level}" IsReadOnly="True" Width="46" />
                <DataGridTextColumn Header="XP" Binding="{Binding XpText}" Width="72" />
                <DataGridTextColumn Header="XP/min" Binding="{Binding XpPerMinute}" IsReadOnly="True" Width="64" />
                <DataGridTextColumn Header="Time" Binding="{Binding Duration}" IsReadOnly="True" Width="62" />
                <DataGridTextColumn Header="Entered" Binding="{Binding Entered}" IsReadOnly="True" Width="96" />
                <DataGridTextColumn Header="Status" Binding="{Binding Status}" IsReadOnly="True" Width="78" />
                <DataGridTemplateColumn Header="" Width="52">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕" Click="Delete_Click" Width="26" Height="22" Padding="0"
                                    HorizontalAlignment="Center" ToolTip="Delete this run" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
