<Window x:Class="DdoGearScanner.DebugSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Debug Settings" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Icon="pack://application:,,,/appicon.ico"
        Background="{StaticResource BgWindow}" Foreground="{StaticResource Parchment}"
        TextOptions.TextFormattingMode="Display">
    <Window.Resources>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Parchment}" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Resources>
    <StackPanel Margin="22,18,22,20">
        <TextBlock Text="Debug" FontSize="18" Style="{StaticResource Title}" />
        <CheckBox Content="Enable debug mode" IsChecked="{Binding DebugMode}" FontWeight="SemiBold" Margin="0,10,0,0" />
        <TextBlock Text="Master switch — everything below is off unless this is on." Foreground="{StaticResource TextMuted}"
                   FontSize="11.5" Margin="22,2,0,0" />

        <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                CornerRadius="4" Padding="14,10,14,14" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Run Tracker" Style="{StaticResource Section}" Margin="0,0,0,2" />
                <CheckBox Content="Show region borders on game (calibrated boxes)"
                          IsChecked="{Binding RunDebugOverlay}" IsEnabled="{Binding DebugMode}" />
                <CheckBox Content="Show detected chat text (live OCR — new lines in green)"
                          IsChecked="{Binding DebugShowChatText}" IsEnabled="{Binding DebugMode}" />
                <CheckBox Content="Save tracker crops (timestamped, for OCR tuning)"
                          IsChecked="{Binding DebugSaveTrackerCrops}" IsEnabled="{Binding DebugMode}" />
            </StackPanel>
        </Border>

        <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                CornerRadius="4" Padding="14,10,14,14" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="Gear Loadout" Style="{StaticResource Section}" Margin="0,0,0,2" />
                <TextBlock Text="(no debug options yet)" Foreground="{StaticResource TextMuted}" FontSize="11.5" Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right" Margin="0,18,0,0" />
    </StackPanel>
</Window>
