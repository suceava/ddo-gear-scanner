<Window x:Class="DdoGearScanner.RunEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit run" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Icon="pack://application:,,,/appicon.ico"
        Background="{StaticResource BgWindow}" Foreground="{StaticResource Parchment}"
        TextOptions.TextFormattingMode="Display">
    <StackPanel Margin="22,16,22,18">
        <TextBlock Text="Edit run" FontSize="17" Style="{StaticResource Title}" Margin="0,0,0,14" />

        <TextBlock Text="Quest" Foreground="{StaticResource TextMuted}" FontSize="12" />
        <TextBox x:Name="NameBox" Margin="0,2,0,12" />

        <TextBlock Text="Character" Foreground="{StaticResource TextMuted}" FontSize="12" />
        <TextBox x:Name="CharacterBox" Margin="0,2,0,12" />

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="110" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Difficulty" Foreground="{StaticResource TextMuted}" FontSize="12" />
                <ComboBox x:Name="DifficultyBox" IsEditable="True" Margin="0,2,0,0">
                    <ComboBoxItem>Casual</ComboBoxItem>
                    <ComboBoxItem>Normal</ComboBoxItem>
                    <ComboBoxItem>Hard</ComboBoxItem>
                    <ComboBoxItem>Elite</ComboBoxItem>
                    <ComboBoxItem>Reaper</ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="Level" Foreground="{StaticResource TextMuted}" FontSize="12" />
                <TextBox x:Name="LevelBox" Margin="0,2,0,0" />
            </StackPanel>
        </Grid>

        <TextBlock x:Name="XpLabel" Text="XP" Foreground="{StaticResource TextMuted}" FontSize="12" />
        <TextBox x:Name="XpBox" Margin="0,2,0,16" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="Cancel_Click" Margin="0,0,8,0" IsCancel="True" />
            <Button Content="Save" Click="Save_Click" IsDefault="True" />
        </StackPanel>
    </StackPanel>
</Window>
