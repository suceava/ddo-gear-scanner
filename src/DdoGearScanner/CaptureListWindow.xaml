<Window x:Class="DdoGearScanner.CaptureListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DdoGearScanner"
        Title="DDO Gear Scanner"
        Width="980" Height="720"
        WindowStartupLocation="Manual"
        Icon="pack://application:,,,/appicon.ico"
        Background="{StaticResource BgWindow}" Foreground="{StaticResource Parchment}">
    <Window.Resources>
        <!-- Loadout slot row (theme-aware) -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="{StaticResource Parchment}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Margin="0,1" Padding="10,7">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SelectionBg}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverBg}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="DDO Gear Scanner" FontSize="19" Style="{StaticResource Title}" VerticalAlignment="Center" />
                <TextBlock Text="Character:" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" Margin="22,0,8,0" />
                <ComboBox x:Name="CharacterSelector" MinWidth="200"
                          SelectionChanged="CharacterSelector_SelectionChanged" VerticalAlignment="Center">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Display}" Foreground="{StaticResource Parchment}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="New" Click="NewCharacter_Click" Margin="8,0,0,0" />
                <Button Content="Edit" Click="EditCharacter_Click" Margin="0" />
            </StackPanel>
            <TextBlock x:Name="StatusText" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,6,0,0"
                       Text="Press the hotkey to start detection, then hover each equipped gear piece." />
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="MenuButton" Content="☰  Menu" Click="Menu_Click" />
            <Popup x:Name="MenuPopup" PlacementTarget="{Binding ElementName=MenuButton}" Placement="Bottom"
                   StaysOpen="False" AllowsTransparency="True" VerticalOffset="3" PopupAnimation="Fade">
                <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderGold}" BorderThickness="1"
                        CornerRadius="4" Padding="4" MinWidth="250">
                    <StackPanel>
                        <Button x:Name="ClearButton" Style="{StaticResource MenuItemButton}"
                                Content="Clear Loadout" Click="ClearList_Click" />
                        <Border Height="1" Background="{StaticResource BorderDim}" Margin="6,5" />
                        <Button x:Name="DetectionButton" Style="{StaticResource MenuItemButton}"
                                Content="Toggle Detection (Off)" Click="DetectionToggle_Click" />
                        <Button x:Name="HotkeyMenuItem" Style="{StaticResource MenuItemButton}"
                                Content="Set Detection Hotkey (Insert)" Click="SetHotkey_Click" />
                        <Button x:Name="CalibrateButton" Style="{StaticResource MenuItemButton}"
                                Content="Calibrate Slots" Click="Calibrate_Click" />
                    </StackPanel>
                </Border>
            </Popup>
            <Button x:Name="MatrixButton" Content="Stacking matrix" Click="Matrix_Click" />
        </StackPanel>

        <!-- Modal prompt shown while waiting for a hotkey keypress -->
        <Border x:Name="BindingPrompt" Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="100"
                Background="#CC100C07" Visibility="Collapsed" Margin="-14">
            <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource GoldBright}" BorderThickness="2"
                    CornerRadius="10" Padding="34,24" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="⌨  Press your detection hotkey" FontSize="20" Style="{StaticResource Title}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="e.g. Insert, or Ctrl+Shift+G" Foreground="{StaticResource Parchment}"
                               FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0" />
                    <TextBlock Text="Esc to cancel" Foreground="{StaticResource TextMuted}"
                               FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0" />
                </StackPanel>
            </Border>
        </Border>

        <!-- Loadout sheet (left) | item detail (right) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E2127" CornerRadius="8" Padding="6">
                <ListBox x:Name="SlotSheet" Background="Transparent" BorderThickness="0"
                         HorizontalContentAlignment="Stretch" SelectionChanged="SlotSheet_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="{StaticResource Gold}"
                                           FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding Badge}" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{StaticResource Gold}" Margin="4,0,2,0" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource Parchment}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasItem}" Value="False">
                                                        <Setter Property="Foreground" Value="#6B6149" />
                                                        <Setter Property="FontWeight" Value="Normal" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Sub}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#16181D" />

            <!-- Item detail -->
            <Border Grid.Column="2" Background="#1E2127" CornerRadius="8" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="{StaticResource BgInput}" CornerRadius="6" Padding="6" Margin="0,0,0,10">
                            <Image x:Name="CropImage" MaxHeight="320" Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>

                        <StackPanel x:Name="ActionBar" Orientation="Horizontal" Margin="0,0,0,10">
                            <Button x:Name="EditButton" Content="Edit item" Click="EditItem_Click" Padding="12,4"
                                    Visibility="Collapsed" />
                            <Button x:Name="AddButton" Content="+ Add item" Click="AddItem_Click" Padding="12,4"
                                    Visibility="Collapsed" />
                            <ToggleButton x:Name="LockButton" Content="🔓 Lock" Click="LockItem_Click" Margin="8,0,0,0"
                                          Padding="10,4" Visibility="Collapsed"
                                          Background="{StaticResource BgRaised}" Foreground="{StaticResource Parchment}"
                                          BorderBrush="{StaticResource BorderGold}" BorderThickness="1" Cursor="Hand"
                                          ToolTip="Locked items are never overwritten by a re-capture." />
                        </StackPanel>

                        <TextBlock x:Name="LastName" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Text="(select a slot)" />
                        <TextBlock x:Name="LastMeta" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,3,0,0" />
                        <TextBlock x:Name="LastReadInfo" Foreground="#6B7280" FontSize="11" Margin="0,2,0,0" />

                        <TextBlock Text="MODS" Style="{StaticResource Section}" />
                        <ItemsControl x:Name="ModsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Split model (DDOBuilderV2): Stat name | Value | BonusType. -->
                                        <TextBlock Grid.Column="0" Text="{Binding Stat}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding ValueText}" Foreground="#8FCF8A"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="2" Text="{Binding BonusType}" Foreground="{StaticResource Gold}"
                                                   Margin="10,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="AUGMENTS" Style="{StaticResource Section}" />
                        <ItemsControl x:Name="AugList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,1">
                                        <Run Text="{Binding Color}" />
                                        <Run Text="{Binding Filled}" Foreground="{StaticResource TextMuted}" />
                                        <Run Text="{Binding IsEmpty, StringFormat='empty={0}'}" Foreground="#6B7280" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="SET BONUSES" Style="{StaticResource Section}" />
                        <ItemsControl x:Name="SetList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SetName}" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="LastBinding" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,8,0,0" />

                        <Expander Header="Raw OCR text" Foreground="{StaticResource TextMuted}" Margin="0,10,0,0">
                            <TextBox x:Name="RawText" IsReadOnly="True" TextWrapping="Wrap"
                                     Background="{StaticResource BgInput}" Foreground="{StaticResource Parchment}" BorderThickness="0"
                                     FontFamily="Consolas" FontSize="12" Height="160"
                                     VerticalScrollBarVisibility="Auto" />
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
