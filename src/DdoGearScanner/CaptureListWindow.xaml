<Window x:Class="DdoGearScanner.CaptureListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DdoGearScanner"
        Title="DDO Gear Scanner"
        Width="980" Height="720"
        WindowStartupLocation="Manual"
        Background="#16181D"
        Foreground="#E8EAED"
        TextElement.Foreground="#E8EAED">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8EAED" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
        <Style x:Key="Section" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7FE0A0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,4" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252932" />
            <Setter Property="Foreground" Value="#E8EAED" />
            <Setter Property="BorderBrush" Value="#31363F" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#11141A" />
            <Setter Property="Foreground" Value="#C8CCD2" />
        </Style>
        <!-- Loadout slot row -->
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E8EAED" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Margin="0,1" Padding="10,7">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2A3550" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#232733" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="DDO Gear Scanner" FontSize="18" FontWeight="SemiBold" />
            <TextBlock x:Name="StatusText" Foreground="#9AA0AB" FontSize="12" Margin="0,4,0,0"
                       Text="Press the hotkey to start detection, then hover each equipped gear piece." />
        </StackPanel>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="DetectionButton" Content="Detection: OFF" Click="DetectionToggle_Click" />
            <Button x:Name="ScanButton" Content="Scan now" Click="ScanNow_Click" />
            <Button x:Name="SetHotkeyButton" Content="Set hotkey" Click="SetHotkey_Click" />
            <Button x:Name="CalibrateButton" Content="Calibrate slots" Click="Calibrate_Click" />
            <Button x:Name="DetectButton" Content="Detect game window" Click="DetectGameWindow_Click" />
            <Button x:Name="MatrixButton" Content="Stacking matrix" Click="Matrix_Click" />
            <Button x:Name="ClearButton" Content="Clear loadout" Click="ClearList_Click" />
            <TextBlock x:Name="HotkeyHint" VerticalAlignment="Center" Foreground="#9AA0AB"
                       FontSize="12" Margin="6,0,0,0" Text="" />
        </StackPanel>

        <!-- Loadout sheet (left) | item detail (right) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#1E2127" CornerRadius="8" Padding="6">
                <ListBox x:Name="SlotSheet" Background="Transparent" BorderThickness="0"
                         HorizontalContentAlignment="Stretch" SelectionChanged="SlotSheet_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" Foreground="#7C9CFF"
                                           FontSize="11" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="14">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#E8EAED" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasItem}" Value="False">
                                                        <Setter Property="Foreground" Value="#5B6270" />
                                                        <Setter Property="FontWeight" Value="Normal" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Sub}" FontSize="11" Foreground="#9AA0AB" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#16181D" />

            <!-- Item detail -->
            <Border Grid.Column="2" Background="#1E2127" CornerRadius="8" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Background="#11141A" CornerRadius="6" Padding="6" Margin="0,0,0,10">
                            <Image x:Name="CropImage" MaxHeight="320" Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                        </Border>

                        <TextBlock x:Name="LastName" FontSize="17" FontWeight="SemiBold" TextWrapping="Wrap"
                                   Text="(select a slot)" />
                        <TextBlock x:Name="LastMeta" Foreground="#9AA0AB" FontSize="12" Margin="0,3,0,0" />
                        <TextBlock x:Name="LastReadInfo" Foreground="#6B7280" FontSize="11" Margin="0,2,0,0" />

                        <TextBlock Text="MODS" Style="{StaticResource Section}" />
                        <ItemsControl x:Name="ModsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <!-- Split model (DDOBuilderV2): Stat name | Value | BonusType. -->
                                        <TextBlock Grid.Column="0" Text="{Binding Stat}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding ValueText}" Foreground="#7FE0A0"
                                                   HorizontalAlignment="Right" />
                                        <TextBlock Grid.Column="2" Text="{Binding BonusType}" Foreground="#7C9CFF"
                                                   Margin="10,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="AUGMENTS" Style="{StaticResource Section}" />
                        <ItemsControl x:Name="AugList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Margin="0,1">
                                        <Run Text="{Binding Color}" />
                                        <Run Text="{Binding Filled}" Foreground="#9AA0AB" />
                                        <Run Text="{Binding IsEmpty, StringFormat='empty={0}'}" Foreground="#6B7280" />
                                    </TextBlock>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="SET BONUSES" Style="{StaticResource Section}" />
                        <ItemsControl x:Name="SetList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding SetName}" TextWrapping="Wrap" Margin="0,1" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock x:Name="LastBinding" Foreground="#9AA0AB" FontSize="12" Margin="0,8,0,0" />

                        <Expander Header="Raw OCR text" Foreground="#9AA0AB" Margin="0,10,0,0">
                            <TextBox x:Name="RawText" IsReadOnly="True" TextWrapping="Wrap"
                                     Background="#11141A" Foreground="#C8CCD2" BorderThickness="0"
                                     FontFamily="Consolas" FontSize="12" Height="160"
                                     VerticalScrollBarVisibility="Auto" />
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>
