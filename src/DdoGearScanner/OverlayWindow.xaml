<Window x:Class="DdoGearScanner.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DDO Gear Scanner Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        SizeToContent="Manual"
        Left="-32000" Top="-32000" Width="1" Height="1">
    <Grid IsHitTestVisible="False">
        <Canvas x:Name="HighlightCanvas">
            <Rectangle x:Name="RegionHighlight"
                       Visibility="Collapsed"
                       Stroke="#FFE0A030"
                       StrokeThickness="3"
                       RadiusX="4" RadiusY="4" />
        </Canvas>
        <Border x:Name="ToastBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,24,0,0"
                Background="#E0101418"
                BorderBrush="#FF35C26B"
                BorderThickness="2"
                CornerRadius="6"
                Padding="16,10"
                Visibility="Collapsed">
            <TextBlock x:Name="ToastText"
                       FontFamily="Segoe UI"
                       FontSize="14"
                       Foreground="White"
                       Text="" />
        </Border>
    </Grid>
</Window>
