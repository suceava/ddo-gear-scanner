<Window x:Class="DdoGearScanner.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DDO Companion Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        SizeToContent="Manual"
        Left="-32000" Top="-32000" Width="1" Height="1">
    <Grid IsHitTestVisible="False">
        <Canvas x:Name="HighlightCanvas">
            <!-- Debug: persistent borders showing the calibrated run-tracker regions -->
            <Rectangle x:Name="DebugPopupBorder" Visibility="Collapsed" Stroke="#E6C66A" StrokeThickness="3" RadiusX="3" RadiusY="3" />
            <TextBlock x:Name="DebugPopupLabel" Visibility="Collapsed" Foreground="#E6C66A" FontFamily="Segoe UI"
                       FontWeight="Bold" FontSize="13" Text="① Quest-entry dialog" />
            <Rectangle x:Name="DebugTrackerBorder" Visibility="Collapsed" Stroke="#6AC6E6" StrokeThickness="3" RadiusX="3" RadiusY="3" />
            <TextBlock x:Name="DebugTrackerLabel" Visibility="Collapsed" Foreground="#6AC6E6" FontFamily="Segoe UI"
                       FontWeight="Bold" FontSize="13" Text="② Quest tracker" />
            <Rectangle x:Name="DebugChatBorder" Visibility="Collapsed" Stroke="#7AD67A" StrokeThickness="3" RadiusX="3" RadiusY="3" />
            <TextBlock x:Name="DebugChatLabel" Visibility="Collapsed" Foreground="#7AD67A" FontFamily="Segoe UI"
                       FontWeight="Bold" FontSize="13" Text="③ Chat log" />
            <Rectangle x:Name="RegionHighlight"
                       Visibility="Collapsed"
                       Stroke="#FFE0A030"
                       StrokeThickness="3"
                       RadiusX="4" RadiusY="4" />
        </Canvas>
        <!-- Gear capture feedback: shown while a session is on but the inventory paper-doll can't be
             located — the silent-failure case (moved window / different UI scale) made visible. -->
        <Border x:Name="SlotHintBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,84,0,0"
                MaxWidth="760"
                Background="#E01A1010"
                BorderBrush="#FFE05C5C"
                BorderThickness="2"
                CornerRadius="6"
                Padding="18,10"
                Visibility="Collapsed">
            <TextBlock x:Name="SlotHintText" FontFamily="Segoe UI" FontSize="15" TextWrapping="Wrap"
                       Foreground="White" Text="" />
        </Border>
        <Border x:Name="ToastBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,24,0,0"
                MaxWidth="680"
                Background="#E0101418"
                BorderBrush="#FF35C26B"
                BorderThickness="2"
                CornerRadius="6"
                Padding="18,12"
                Visibility="Collapsed">
            <TextBlock x:Name="ToastText"
                       FontFamily="Segoe UI"
                       FontSize="16"
                       TextWrapping="Wrap"
                       Foreground="White"
                       Text="" />
        </Border>
    </Grid>
</Window>
