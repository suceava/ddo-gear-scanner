<Window x:Class="DdoGearScanner.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Icon="pack://application:,,,/appicon.ico"
        Background="{StaticResource BgWindow}" Foreground="{StaticResource Parchment}"
        TextOptions.TextFormattingMode="Display">
    <StackPanel Margin="22,18,22,20">
        <TextBlock Text="Settings" FontSize="18" Style="{StaticResource Title}" />

        <Border Background="{StaticResource BgPanel}" BorderBrush="{StaticResource BorderDim}" BorderThickness="1"
                CornerRadius="4" Padding="14,10,14,14" Margin="0,14,0,0">
            <StackPanel>
                <TextBlock Text="AI reading (OpenRouter)" Style="{StaticResource Section}" Margin="0,0,0,2" />
                <TextBlock Foreground="{StaticResource TextMuted}" FontSize="11.5" TextWrapping="Wrap" Margin="0,2,0,8"
                           Text="Uses an AI vision model to read gear tooltips, quest-entry popups and your character info — much more accurate than local OCR. Applies app-wide, only at capture moments (a read costs a fraction of a cent); continuous detection stays local and free. Requires an OpenRouter account and API key (openrouter.ai)." />

                <CheckBox Content="Use AI to read captures" IsChecked="{Binding LlmEnabled}"
                          Foreground="{StaticResource Parchment}" FontWeight="SemiBold" />

                <TextBlock Text="API key" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,10,0,0" />
                <TextBox x:Name="ApiKeyBox" Text="{Binding OpenRouterApiKey, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0"
                         FontFamily="Consolas" />
                <TextBlock Text="Stored in settings.json on this machine." Foreground="{StaticResource TextMuted}" FontSize="10.5" Margin="0,2,0,0" />

                <TextBlock Text="Model" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,10,0,0" />
                <TextBox Text="{Binding OpenRouterModel, UpdateSourceTrigger=PropertyChanged}" Margin="0,2,0,0" FontFamily="Consolas" />
                <TextBlock Text="Any OpenRouter vision-capable model id. Default: google/gemini-2.5-flash (fast + cheap)."
                           Foreground="{StaticResource TextMuted}" FontSize="10.5" Margin="0,2,0,0" />

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button x:Name="TestButton" Content="Test connection" Click="Test_Click" />
                    <TextBlock x:Name="TestResult" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="12"
                               Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" MaxWidth="300" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Button Content="Close" Click="Close_Click" HorizontalAlignment="Right" Margin="0,16,0,0" />
    </StackPanel>
</Window>
