<Window x:Class="DdoGearScanner.CharacterEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Character" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource BgWindow}" Foreground="{StaticResource Parchment}">
    <Window.Resources>
        <!-- form labels (spacing) -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
            <Setter Property="Margin" Value="0,10,0,3" />
        </Style>
    </Window.Resources>
    <StackPanel Margin="18">
        <TextBlock x:Name="Heading" Text="New Character" FontSize="17" Style="{StaticResource Title}" Margin="0,0,0,6" />

        <TextBlock Text="Name" />
        <TextBox x:Name="NameBox" />

        <TextBlock Text="Playstyle  (drives the gear-stat priority ranking)" />
        <ComboBox x:Name="PlaystyleBox" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="DeleteButton" Content="Delete" Click="Delete_Click" Background="#3A2018"
                    BorderBrush="#7A4030" Margin="0,0,16,0" Visibility="Collapsed" />
            <Button Content="Cancel" Click="Cancel_Click" Margin="8,0,0,0" />
            <Button Content="Save" Click="Save_Click" Background="{StaticResource SelectionBg}" Margin="8,0,0,0" />
        </StackPanel>
    </StackPanel>
</Window>
