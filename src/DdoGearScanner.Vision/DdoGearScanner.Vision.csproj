<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenCvSharp4" Version="4.13.0.20260427" />
    <PackageReference Include="OpenCvSharp4.runtime.win" Version="4.13.0.20260302" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\DdoGearScanner.Model\DdoGearScanner.Model.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Data\gear-priorities.json" />
    <!-- DDOBuilder's authoritative bonus-type stacking rules (generated by tools/DdoDataImporter). -->
    <EmbeddedResource Include="..\..\data\bonustypes.json" LogicalName="bonustypes.json" />
    <!-- DDOBuilder item catalog (generated by tools/DdoDataImporter) for named-item matching. -->
    <EmbeddedResource Include="..\..\data\items.json" LogicalName="items.json" />
    <!-- Rag-doll anchor template for inventory slot detection, embedded so the single-file exe is self-contained. -->
    <EmbeddedResource Include="..\..\assets\inventory\ragdoll.png" LogicalName="ragdoll.png" />
  </ItemGroup>

</Project>
